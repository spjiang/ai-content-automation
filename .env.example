# ── 数据库 ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://appuser:changeme@postgres:5432/ai_content
POSTGRES_DB=ai_content
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme

# ── 消息队列 ────────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:changeme@rabbitmq:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=changeme

# ── 缓存 ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ──────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://guest:changeme@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── DeepSeek ────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_RETRIES=3

# ── 应用 ────────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret
PACKAGE_STORAGE_DIR=/data/packages

# ── 可观测性（M3）──────────────────────────────────────────────────────────────
# LOG_FORMAT=json
# LOG_LEVEL=INFO
# METRICS_WINDOW_DAYS=7
# CELERY_QUEUE_BACKLOG_WARN=80
# GENERATION_FAILURE_RATE_WARN=0.25

# 前端 Vite 代理（Docker 内开发可设为 http://backend:8000）
# VITE_API_PROXY_TARGET=http://backend:8000

# ── 抓取器 ──────────────────────────────────────────────────────────────────────
COLLECTOR_RETRY_MAX=3
COLLECTOR_RETRY_BACKOFF_BASE=2
COLLECTOR_FAILURE_ALERT_THRESHOLD=5
